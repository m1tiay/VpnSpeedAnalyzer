<Window x:Class="VpnSpeedAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="VPN Speed Analyzer"
        Width="1100" Height="700"
        MinWidth="980" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#141622">
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#141622"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#1D2033"/>
        <SolidColorBrush x:Key="PanelSecondaryBrush" Color="#232741"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#9146FF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F2F4FF"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A8B0D9"/>
        <SolidColorBrush x:Key="OkBrush" Color="#59D9B7"/>
        <SolidColorBrush x:Key="WaitBrush" Color="#A8B0D9"/>
        <SolidColorBrush x:Key="CheckBrush" Color="#F6C453"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FF7AA2"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#232741"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F2F4FF"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#232741"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#232741"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#F2F4FF"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#232741"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#F2F4FF"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#9146FF"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="8,12,8,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Margin="10,-8,0,0"
                                    Padding="6,0,6,0">
                                <TextBlock Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2C3255"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#B07DFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#171A2C"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#7D4DD9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#1D2033"/>
            <Setter Property="AlternatingRowBackground" Value="#232741"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2A2F4F"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#1B1F34"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelSecondaryBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#2F3458"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelSecondaryBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource PanelSecondaryBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2A2F4A"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#30365B"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridSplitter">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="{StaticResource PanelSecondaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12" Background="{StaticResource BgBrush}">
        <TabControl Background="{StaticResource BgBrush}" BorderThickness="0">
            <TabItem Header="Мониторинг">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1.25*"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="2.1*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                        <DockPanel LastChildFill="True">
                            <Grid DockPanel.Dock="Left" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="IP:" FontWeight="Bold" Margin="0,0,8,0" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentIp}" Margin="0,0,16,0" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Страна:" FontWeight="Bold" Margin="0,0,8,0" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding CurrentCountry}" Margin="0,0,16,0" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="ASN:" FontWeight="Bold" Margin="0,0,8,0" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="{Binding CurrentAsn}" Margin="0,0,16,0" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="Профиль:" FontWeight="Bold" Margin="0,0,8,0" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="7"
                                          Width="120"
                                          Height="28"
                                          Margin="0"
                                          VerticalAlignment="Center"
                                          ItemsSource="{Binding ScoringProfiles}"
                                          SelectedItem="{Binding SelectedScoringProfile}"/>
                            </Grid>

                            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{Binding StatusColor}"/>
                                <TextBlock Text="{Binding RecommendationText}" HorizontalAlignment="Right" Margin="0,4,0,0" Foreground="{StaticResource TextBrush}" FontSize="11"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource OkBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="ОК" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,0" FontSize="11"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource CheckBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="Проверка" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,0" FontSize="11"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource WaitBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="Ожидание" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,0" FontSize="11"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource ErrorBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="Ошибка" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,10,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <GroupBox Grid.Column="0" Header="Дрожание (мс)" Margin="0">
                            <sp:WpfPlot x:Name="JitterPlot" Margin="-6,-4,-6,-6"/>
                        </GroupBox>
                        <GroupBox Grid.Column="2" Header="Пинг (мс)" Margin="0">
                            <sp:WpfPlot x:Name="PingPlot" Margin="-6,-4,-6,-6"/>
                        </GroupBox>
                    </Grid>

                    <GridSplitter Grid.Row="2"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Height="6"
                                  Background="{StaticResource PanelSecondaryBrush}"
                                  ResizeDirection="Rows"
                                  ShowsPreview="False"/>

                    <Border Grid.Row="3" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="8" Margin="0,10,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.3*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <DataGrid ItemsSource="{Binding Results}" SelectedItem="{Binding SelectedResult}" AutoGenerateColumns="False" CanUserAddRows="False" Grid.Column="0" FontSize="12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="*"/>
                                    <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="*"/>
                                    <DataGridTextColumn Header="D.Q.S" Binding="{Binding Score}" Width="0.8*"/>
                                    <DataGridTextColumn Header="Пинг" Binding="{Binding Ping}" Width="*"/>
                                    <DataGridTextColumn Header="Дрожание" Binding="{Binding Jitter}" Width="*"/>
                                    <DataGridTextColumn Header="Потери" Binding="{Binding Loss}" Width="*"/>
                                    <DataGridTextColumn Header="Загрузка" Binding="{Binding Download}" Width="*"/>
                                    <DataGridTextColumn Header="Отдача" Binding="{Binding Upload}" Width="*"/>
                                    <DataGridTextColumn Header="Время" Binding="{Binding Timestamp}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Padding="10" Background="#171A2C" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="Почему этот D.Q.S?" Foreground="{StaticResource MutedTextBrush}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedResult.ScoreDetails, TargetNullValue='Выбери строку в таблице, чтобы увидеть расшифровку оценки.'}"
                                               Foreground="{StaticResource TextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Grid.RowSpan="2" Background="#171A2C" CornerRadius="8" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Рейтинг хостов" Foreground="{StaticResource TextBrush}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="Топ по D.Q.S" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,2,0,8"/>
                                    <TextBlock Text="D.Q.S = Daver Quality Score" Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding TopHosts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#20243C" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Country}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Ip}" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" Background="#2D3150" CornerRadius="6" Padding="8,3">
                                                            <TextBlock Text="{Binding Score, StringFormat=F2}" Foreground="{StaticResource OkBrush}" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Margin="0,8,0,0" Text="{Binding RecommendationText}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{Binding ToggleMonitoringButtonText}" Width="130" Command="{Binding ToggleMonitoringCommand}"/>
                        <Button Content="Экспорт CSV" Width="140" Command="{Binding ExportCsvCommand}"/>
                        <Button Content="{Binding ToggleBestOnlyButtonText}" Width="150" Command="{Binding ToggleBestOnlyCommand}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Рейтинг хостов">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="Рейтинг хостов" Foreground="{StaticResource TextBrush}" FontWeight="Bold" FontSize="18"/>
                                <TextBlock Text="Топ узлов по текущему профилю D.Q.S" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Профиль:" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                                <ComboBox Width="118" Height="28"
                                          ItemsSource="{Binding ScoringProfiles}"
                                          SelectedItem="{Binding SelectedScoringProfile}"
                                          Margin="0,0,12,0"/>
                                <Button Content="Экспорт топа CSV" Width="150" Command="{Binding ExportTopHostsCsvCommand}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DataGrid ItemsSource="{Binding TopHosts}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#1D2033"/>
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Rank}" Value="1">
                                            <Setter Property="Background" Value="#3B2F10"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Rank}" Value="2">
                                            <Setter Property="Background" Value="#2D3440"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Rank}" Value="3">
                                            <Setter Property="Background" Value="#3A2A24"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="" Width="0.35*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RankMarker}"
                                                       Foreground="{Binding RankMarkerColor}"
                                                       FontSize="15"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Место" Binding="{Binding Rank}" Width="0.6*" SortMemberPath="Rank"/>
                                <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="*"/>
                                <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="*"/>
                                <DataGridTextColumn Header="D.Q.S" Binding="{Binding Score, StringFormat=F2}" Width="0.8*" SortMemberPath="Score"/>
                                <DataGridTextColumn Header="Пинг" Binding="{Binding Ping}" Width="0.8*" SortMemberPath="Ping"/>
                                <DataGridTextColumn Header="Дрожание" Binding="{Binding Jitter}" Width="0.8*" SortMemberPath="Jitter"/>
                                <DataGridTextColumn Header="Потери" Binding="{Binding Loss}" Width="0.8*" SortMemberPath="Loss"/>
                                <DataGridTextColumn Header="Загрузка" Binding="{Binding Download}" Width="0.8*" SortMemberPath="Download"/>
                                <DataGridTextColumn Header="Отдача" Binding="{Binding Upload}" Width="0.8*" SortMemberPath="Upload"/>
                            </DataGrid.Columns>
                        </DataGrid>
                            <TextBlock Grid.Row="1"
                                       Margin="0,8,0,0"
                                       Text="{Binding RecommendationText}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
