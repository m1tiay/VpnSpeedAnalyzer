<Window x:Class="VpnSpeedAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VpnSpeedAnalyzer"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="VPN Speed Analyzer"
        Width="1100" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- Верхняя панель -->
            <RowDefinition Height="260"/>      <!-- Графики -->
            <RowDefinition Height="*"/>        <!-- Таблица -->
            <RowDefinition Height="Auto"/>     <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <Border Grid.Row="0" Padding="10" Background="#FFFFFF" CornerRadius="6"
                BorderBrush="#DDDDDD" BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="20">

                <TextBlock Text="IP:" FontWeight="Bold"/>
                <TextBlock Text="{Binding CurrentIp}" />

                <TextBlock Text="{Binding CurrentFlag}" FontSize="18" />

                <TextBlock Text="{Binding CurrentCountry}" />

                <TextBlock Text="ASN:" FontWeight="Bold" Margin="20,0,0,0"/>
                <TextBlock Text="{Binding CurrentAsn}" />

                <TextBlock Text="Status:" FontWeight="Bold" Margin="20,0,0,0"/>
                <TextBlock Text="{Binding StatusText}" />
            </StackPanel>
        </Border>

        <!-- ГРАФИКИ -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- JITTER -->
            <Border Grid.Column="0" Margin="0,0,10,0" Background="#FFFFFF"
                    CornerRadius="6" BorderBrush="#DDDDDD" BorderThickness="1">
                <Grid>
                    <TextBlock Text="Jitter (ms)" Margin="10" FontWeight="Bold"/>
                    <scottplot:WpfPlot Name="JitterPlot" Margin="0,30,0,0"/>
                </Grid>
            </Border>

            <!-- PING -->
            <Border Grid.Column="1" Margin="10,0,0,0" Background="#FFFFFF"
                    CornerRadius="6" BorderBrush="#DDDDDD" BorderThickness="1">
                <Grid>
                    <TextBlock Text="Ping (ms)" Margin="10" FontWeight="Bold"/>
                    <scottplot:WpfPlot Name="PingPlot" Margin="0,30,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ТАБЛИЦА -->
        <Border Grid.Row="2" Background="#FFFFFF" CornerRadius="6"
                BorderBrush="#DDDDDD" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Results}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      RowHeight="28"
                      FontSize="14">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="*"/>
                    <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="*"/>
                    <DataGridTextColumn Header="Ping" Binding="{Binding Ping}" Width="70"/>
                    <DataGridTextColumn Header="Jitter" Binding="{Binding Jitter}" Width="70"/>
                    <DataGridTextColumn Header="Loss" Binding="{Binding Loss}" Width="70"/>
                    <DataGridTextColumn Header="DL Mbps" Binding="{Binding Download}" Width="90"/>
                    <DataGridTextColumn Header="UL Mbps" Binding="{Binding Upload}" Width="90"/>
                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="150"/>
                </DataGrid.Columns>

            </DataGrid>
        </Border>

        <!-- КНОПКИ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,10,0,0" Spacing="20">

            <Button Content="Start Monitoring" Width="160" Height="36"
                    Command="{Binding StartCommand}"/>

            <Button Content="Stop" Width="120" Height="36"
                    Command="{Binding StopCommand}"/>

            <Button Content="Export CSV" Width="140" Height="36"
                    Command="{Binding ExportCsvCommand}"/>

            <Button Content="Show Best Only" Width="160" Height="36"
                    Command="{Binding ToggleBestOnlyCommand}"/>
        </StackPanel>

    </Grid>
</Window>
