<Window x:Class="VpnSpeedAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="VPN Speed Analyzer"
        Width="1100" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#141622">
    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#141622"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#1D2033"/>
        <SolidColorBrush x:Key="PanelSecondaryBrush" Color="#232741"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#9146FF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F2F4FF"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A8B0D9"/>
        <SolidColorBrush x:Key="OkBrush" Color="#59D9B7"/>
        <SolidColorBrush x:Key="WaitBrush" Color="#A8B0D9"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FF7AA2"/>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0.8"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2C3255"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#B07DFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#171A2C"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#7D4DD9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#1D2033"/>
            <Setter Property="AlternatingRowBackground" Value="#232741"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2A2F4F"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12" Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP PANEL -->
        <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="12" Margin="0 0 0 10">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="IP:" FontWeight="Bold" Margin="0 0 8 0" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding CurrentIp}" Margin="0 0 16 0" Foreground="{StaticResource TextBrush}"/>

                    <TextBlock Text="Страна:" FontWeight="Bold" Margin="0 0 8 0" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding CurrentCountry}" Margin="0 0 16 0" Foreground="{StaticResource TextBrush}"/>

                    <TextBlock Text="ASN:" FontWeight="Bold" Margin="0 0 8 0" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding CurrentAsn}" Margin="0 0 16 0" Foreground="{StaticResource TextBrush}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{Binding StatusColor}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource OkBrush}" Margin="0,0,4,0"/>
                        <TextBlock Text="ОК" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,0" FontSize="11"/>
                        <Ellipse Width="8" Height="8" Fill="{StaticResource WaitBrush}" Margin="0,0,4,0"/>
                        <TextBlock Text="Ожидание" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,0" FontSize="11"/>
                        <Ellipse Width="8" Height="8" Fill="{StaticResource ErrorBrush}" Margin="0,0,4,0"/>
                        <TextBlock Text="Ошибка" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- JITTER PLOT -->
        <GroupBox Header="Дрожание (мс)" Grid.Row="1">
            <sp:WpfPlot x:Name="JitterPlot"/>
        </GroupBox>

        <!-- PING PLOT -->
        <GroupBox Header="Пинг (мс)" Grid.Row="2">
            <sp:WpfPlot x:Name="PingPlot"/>
        </GroupBox>

        <!-- RESULTS TABLE -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="8" Margin="0 0 0 10">
            <DataGrid ItemsSource="{Binding Results}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="*"/>
                    <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="*"/>
                    <DataGridTextColumn Header="Пинг" Binding="{Binding Ping}" Width="*"/>
                    <DataGridTextColumn Header="Дрожание" Binding="{Binding Jitter}" Width="*"/>
                    <DataGridTextColumn Header="Потери" Binding="{Binding Loss}" Width="*"/>
                    <DataGridTextColumn Header="Загрузка" Binding="{Binding Download}" Width="*"/>
                    <DataGridTextColumn Header="Отдача" Binding="{Binding Upload}" Width="*"/>
                    <DataGridTextColumn Header="Время" Binding="{Binding Timestamp}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="{Binding ToggleMonitoringButtonText}" Width="130" Command="{Binding ToggleMonitoringCommand}"/>
            <Button Content="Экспорт CSV" Width="140" Command="{Binding ExportCsvCommand}"/>
            <Button Content="{Binding ToggleBestOnlyButtonText}" Width="150" Command="{Binding ToggleBestOnlyCommand}"/>
        </StackPanel>

    </Grid>
</Window>
