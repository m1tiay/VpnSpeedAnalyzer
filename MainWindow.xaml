<Window x:Class="VpnSpeedAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="VPN Speed Analyzer"
        Width="1100" Height="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP PANEL -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
            <TextBlock Text="IP:" FontWeight="Bold" Margin="0 0 10 0"/>
            <TextBlock Text="{Binding CurrentIp}" Margin="0 0 20 0"/>

            <TextBlock Text="{Binding CurrentCountry}" Margin="0 0 20 0"/>
            <TextBlock Text="ASN:" FontWeight="Bold" Margin="0 0 10 0"/>
            <TextBlock Text="{Binding CurrentAsn}" Margin="0 0 20 0"/>

            <TextBlock Text="{Binding StatusText}" FontWeight="Bold" Foreground="DarkGreen"/>
        </StackPanel>

        <!-- JITTER PLOT -->
        <GroupBox Header="Jitter" Grid.Row="1" Margin="0 0 0 10">
            <sp:WpfPlot x:Name="JitterPlot"/>
        </GroupBox>

        <!-- PING PLOT -->
        <GroupBox Header="Ping" Grid.Row="2" Margin="0 0 0 10">
            <sp:WpfPlot x:Name="PingPlot"/>
        </GroupBox>

        <!-- RESULTS TABLE -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Results}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Margin="0 0 0 10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="*"/>
                <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="*"/>
                <DataGridTextColumn Header="Ping" Binding="{Binding Ping}" Width="*"/>
                <DataGridTextColumn Header="Jitter" Binding="{Binding Jitter}" Width="*"/>
                <DataGridTextColumn Header="Loss" Binding="{Binding Loss}" Width="*"/>
                <DataGridTextColumn Header="Download" Binding="{Binding Download}" Width="*"/>
                <DataGridTextColumn Header="Upload" Binding="{Binding Upload}" Width="*"/>
                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Start" Width="120" Margin="5" Command="{Binding StartCommand}"/>
            <Button Content="Stop" Width="120" Margin="5" Command="{Binding StopCommand}"/>
            <Button Content="Export CSV" Width="120" Margin="5" Command="{Binding ExportCsvCommand}"/>
            <Button Content="Show Best Only" Width="150" Margin="5" Command="{Binding ToggleBestOnlyCommand}"/>
        </StackPanel>

    </Grid>
</Window>
