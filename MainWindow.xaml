<Window x:Class="VpnSpeedAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sp="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
        xmlns:conv="clr-namespace:VpnSpeedAnalyzer.Converters"
        mc:Ignorable="d"
        Title="VPN Speed Analyzer"
        Width="1180" Height="760"
        MinWidth="1024" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/icon.ico"
        Background="#141622">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:ProgressBarIndicatorWidthConverter x:Key="PbWidthConv"/>

        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#232741"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F2F4FF"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#232741"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#232741"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#F2F4FF"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#232741"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#F2F4FF"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#9146FF"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="8,12,8,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Margin="10,-8,0,0"
                                    Padding="6,0,6,0">
                                <TextBlock Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopNavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="130"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#1D2033"/>
            <Setter Property="AlternatingRowBackground" Value="#232741"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2A2F4F"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#1D2033"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource OkBrush}"/>
                    <Setter Property="Foreground" Value="#0E1A22"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="Selector.IsSelectionActive" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource OkBrush}"/>
                    <Setter Property="Foreground" Value="#0E1A22"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource OkBrush}"/>
                    <Setter Property="Foreground" Value="#0E1A22"/>
                    <Setter Property="BorderBrush" Value="{StaticResource OkBrush}"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="Selector.IsSelectionActive" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource OkBrush}"/>
                    <Setter Property="Foreground" Value="#0E1A22"/>
                    <Setter Property="BorderBrush" Value="{StaticResource OkBrush}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#1B1F34"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="0"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="8,0,8,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  x:Name="DropDownToggle"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Cursor="Hand">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="ArrowHost"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ArrowHost" Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="ArrowHost" Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                        <Path Width="10"
                                              Height="6"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"
                                              Opacity="0"
                                              Fill="{StaticResource TextBrush}"
                                              Data="M 0 0 L 10 0 L 5 6 Z"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        Background="{StaticResource PanelSecondaryBrush}"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer Margin="2"
                                                  CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#B07DFF"/>
                                <Setter TargetName="ComboBorder" Property="Background" Value="#242944"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#B07DFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelSecondaryBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ToolTipService.ShowDuration" Value="120000"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="2"
                                Padding="6,4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2F3458"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#B07DFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Content" Value="Универсальный">
                    <Setter Property="ToolTip" Value="Сбалансированный профиль: задержка, стабильность и скорость учитываются равномерно."/>
                </Trigger>
                <Trigger Property="Content" Value="Игры">
                    <Setter Property="ToolTip" Value="Профиль для игр: основной упор на минимальный пинг, джиттер и потери."/>
                </Trigger>
                <Trigger Property="Content" Value="Стрим">
                    <Setter Property="ToolTip" Value="Профиль для стрима: выше приоритет скоростей загрузки и отдачи при приемлемой задержке."/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource BgBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter x:Name="PART_SelectedContentHost"
                                          ContentSource="SelectedContent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelSecondaryBrush}"/>
            <Setter Property="Width" Value="130"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource PanelSecondaryBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2C3255"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#B07DFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="#2C3255"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#B07DFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </MultiTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2C3255"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#B07DFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridSplitter">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="{StaticResource PanelSecondaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ProgressBar}">
            <Setter Property="Background" Value="#1B1F34"/>
            <Setter Property="Foreground" Value="{StaticResource OkBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="MinHeight" Value="6"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Border CornerRadius="2"
                                Background="{TemplateBinding Background}"
                                ClipToBounds="True">
                            <Grid>
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="2">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource PbWidthConv}">
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="ActualWidth"/>
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value"/>
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Minimum"/>
                                            <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Maximum"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                                <Border x:Name="IndeterminateGlow"
                                        Width="120"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="2"
                                        Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="IndeterminateTransform" X="-120"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="IndeterminateGlow" Property="Opacity" Value="0.9"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="IndeterminateStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetName="IndeterminateTransform"
                                                Storyboard.TargetProperty="X"
                                                From="-120" To="900" Duration="0:0:1.6"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="IndeterminateStoryboard"/>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12" Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="8,0,8,8" LastChildFill="False">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="Мониторинг"
                        Command="{Binding ShowMonitoringTabCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TopNavButtonStyle}">
                            <Setter Property="Margin" Value="0,0,8,0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMonitoringTabSelected}" Value="True">
                                    <Setter Property="Background" Value="#2C3255"/>
                                    <Setter Property="BorderBrush" Value="#59D9B7"/>
                                    <Setter Property="Foreground" Value="#59D9B7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Аналитика"
                        Command="{Binding ShowAnalyticsTabCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TopNavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAnalyticsTabSelected}" Value="True">
                                    <Setter Property="Background" Value="#2C3255"/>
                                    <Setter Property="BorderBrush" Value="#59D9B7"/>
                                    <Setter Property="Foreground" Value="#59D9B7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Top">
                <TextBlock Text="{Binding VpnProcessInfoText}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Text="Профиль:" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Width="{Binding ScoringProfileComboWidth}"
                          Height="30"
                          Margin="0"
                          VerticalAlignment="Top"
                          ItemsSource="{Binding ScoringProfiles}"
                          SelectedItem="{Binding SelectedScoringProfile}"/>
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1"
                    Background="{StaticResource BgBrush}"
                    BorderThickness="0"
                    SelectedIndex="{Binding SelectedMainTabIndex}">
            <TabItem Header="Мониторинг">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1.25*"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="2.1*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="IP:" FontWeight="Bold" Margin="0,0,8,0" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CurrentIp}" Margin="0,0,16,0" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Страна:" FontWeight="Bold" Margin="0,0,8,0" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding CurrentCountry}" Margin="0,0,16,0" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="ASN:" FontWeight="Bold" Margin="0,0,8,0" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="{Binding CurrentAsn}" Margin="0,0,16,0" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding RecommendationText}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <StackPanel Grid.Column="1" Width="300" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusText}"
                                           Width="300"
                                           HorizontalAlignment="Right"
                                           TextAlignment="Right"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="Bold"
                                           Foreground="{Binding StatusColor}"/>
                                <ProgressBar Width="240"
                                             Height="6"
                                             Margin="0,6,0,0"
                                             HorizontalAlignment="Right"
                                             IsIndeterminate="{Binding ProgressIsIndeterminate}"
                                             Value="{Binding ProgressValue, Mode=OneWay}"
                                             Foreground="{Binding ProgressColor}"
                                             Maximum="100">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                            <Setter Property="Opacity" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProgressVisible}" Value="False">
                                                    <Setter Property="Opacity" Value="0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource OkBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="ОК" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,0" FontSize="11"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource CheckBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="Проверка" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,0" FontSize="11"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource WaitBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="Ожидание" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,0" FontSize="11"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource ErrorBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="Ошибка" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <GroupBox Grid.Column="0" Header="Джиттер (мс)" Margin="0">
                            <sp:WpfPlot x:Name="JitterPlot" Margin="-6,-4,-6,-6"/>
                        </GroupBox>
                        <GroupBox Grid.Column="2" Header="Пинг (мс)" Margin="0">
                            <sp:WpfPlot x:Name="PingPlot" Margin="-6,-4,-6,-6"/>
                        </GroupBox>
                    </Grid>

                    <GridSplitter Grid.Row="2"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Height="6"
                                  Background="{StaticResource PanelSecondaryBrush}"
                                  ResizeDirection="Rows"
                                  ShowsPreview="False"/>

                    <Border Grid.Row="3" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="8" Margin="0,8,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.3*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="8" BorderBrush="{StaticResource PanelSecondaryBrush}" BorderThickness="1" ClipToBounds="True">
                                <DataGrid ItemsSource="{Binding Results}" SelectedItem="{Binding SelectedResult}" IsSynchronizedWithCurrentItem="False" AutoGenerateColumns="False" CanUserAddRows="False" FontSize="12">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Rank}" Value="1"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="#3B2F10"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Rank}" Value="2"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="#2D3440"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Rank}" Value="3"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="#3A2A24"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="" Width="0.55*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding RankMarker}"
                                                               Foreground="{Binding RankMarkerColor}"
                                                               ToolTip="{Binding RankMarkerToolTip}"
                                                               FontSize="14"
                                                               TextAlignment="Center"
                                                               Margin="0,-1,0,0"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Место" Binding="{Binding Rank}" Width="0.6*" SortMemberPath="Rank"/>
                                        <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="*"/>
                                        <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="*"/>
                                        <DataGridTextColumn Header="D.Q.S" Binding="{Binding Score, StringFormat=F2}" Width="0.8*" SortMemberPath="Score"/>
                                        <DataGridTextColumn Header="Пинг" Binding="{Binding Ping}" Width="0.8*" SortMemberPath="Ping"/>
                                        <DataGridTextColumn Header="Джиттер" Binding="{Binding Jitter}" Width="0.8*" SortMemberPath="Jitter"/>
                                        <DataGridTextColumn Header="Потери" Binding="{Binding Loss}" Width="0.8*" SortMemberPath="Loss"/>
                                        <DataGridTextColumn Header="Загрузка" Binding="{Binding Download}" Width="0.8*" SortMemberPath="Download"/>
                                        <DataGridTextColumn Header="Отдача" Binding="{Binding Upload}" Width="0.8*" SortMemberPath="Upload"/>
                                        <DataGridTemplateColumn Header="" Width="0.55*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding MeasurementMarker}"
                                                               Foreground="{Binding MeasurementMarkerColor}"
                                                               ToolTip="{Binding MeasurementMarkerToolTip}"
                                                               FontSize="12"
                                                               FontWeight="Normal"
                                                               Opacity="0.78"
                                                               TextAlignment="Center"
                                                               Margin="0,-1,0,0"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLatestMeasurement}" Value="True">
                                                                        <Setter Property="FontSize" Value="13"/>
                                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Padding="10" Background="#171A2C" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="Почему этот D.Q.S?" Foreground="{StaticResource MutedTextBrush}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedResult.ScoreDetails, TargetNullValue='Выбери строку в таблице, чтобы увидеть расшифровку оценки.'}"
                                               Foreground="{StaticResource TextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Grid.RowSpan="2" Background="#171A2C" CornerRadius="8" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Рейтинг хостов" Foreground="{StaticResource TextBrush}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="Топ по D.Q.S" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,2,0,8"/>
                                    <TextBlock Text="D.Q.S = Daver Quality Score" Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding TopHosts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#20243C" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Country}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Ip}" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" Background="#2D3150" CornerRadius="6" Padding="8,3">
                                                            <TextBlock Text="{Binding Score, StringFormat=F2}" Foreground="{StaticResource OkBrush}" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                </Grid>
            </TabItem>

            <TabItem Header="Аналитика">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="IP:" FontWeight="Bold" Margin="0,0,8,0" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CurrentIp}" Margin="0,0,16,0" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Страна:" FontWeight="Bold" Margin="0,0,8,0" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding CurrentCountry}" Margin="0,0,16,0" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="ASN:" FontWeight="Bold" Margin="0,0,8,0" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="{Binding CurrentAsn}" Margin="0,0,16,0" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding RecommendationText}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <StackPanel Grid.Column="1" Width="300" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusText}"
                                           Width="300"
                                           HorizontalAlignment="Right"
                                           TextAlignment="Right"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="Bold"
                                           Foreground="{Binding StatusColor}"/>
                                <ProgressBar Width="240"
                                             Height="6"
                                             Margin="0,6,0,0"
                                             HorizontalAlignment="Right"
                                             IsIndeterminate="{Binding ProgressIsIndeterminate}"
                                             Value="{Binding ProgressValue, Mode=OneWay}"
                                             Foreground="{Binding ProgressColor}"
                                             Maximum="100">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                            <Setter Property="Opacity" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProgressVisible}" Value="False">
                                                    <Setter Property="Opacity" Value="0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource OkBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="ОК" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,0" FontSize="11"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource CheckBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="Проверка" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,0" FontSize="11"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource WaitBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="Ожидание" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,0" FontSize="11"/>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource ErrorBrush}" Margin="0,0,4,0"/>
                                    <TextBlock Text="Ошибка" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,8,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <UniformGrid Rows="1" Columns="4" Grid.Row="0" Margin="-4,0,-4,0">
                                <GroupBox Header="Всего замеров" Margin="4,0,4,0">
                                    <TextBlock Text="{Binding TotalMeasurements}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                </GroupBox>
                                <GroupBox Header="Уникальных хостов" Margin="4,0,4,0">
                                    <TextBlock Text="{Binding UniqueHostsCount}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                </GroupBox>
                                <GroupBox Header="Ср. D.Q.S" Margin="4,0,4,0"
                                          ToolTip="D.Q.S — итоговая оценка качества соединения. Чем больше, тем лучше: «+Δ» лучше, «−Δ» хуже.">
                                    <Grid HorizontalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Width="88" Text="{Binding CmpDqsLeaderText}" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold" TextAlignment="Right"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Width="14" Text="{Binding CmpDqsSeparatorText}" Foreground="{StaticResource MutedTextBrush}" FontSize="16" FontWeight="Normal" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Width="88" Text="{Binding CmpDqsDeltaText}" Foreground="{Binding CmpDqsDeltaBrush}" FontSize="20" FontWeight="SemiBold" TextAlignment="Left"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Width="88" Text="лидер" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Right"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Width="14" Text="|" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Width="88" Text="выбранный" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Left"/>
                                    </Grid>
                                </GroupBox>
                                <GroupBox Header="Ср. пинг, мс" Margin="4,0,4,0"
                                          ToolTip="Пинг — задержка отклика в мс. Чем меньше, тем лучше: «+Δ» хуже, «−Δ» лучше.">
                                    <Grid HorizontalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Width="88" Text="{Binding CmpPingLeaderText}" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold" TextAlignment="Right"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Width="14" Text="{Binding CmpPingSeparatorText}" Foreground="{StaticResource MutedTextBrush}" FontSize="16" FontWeight="Normal" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Width="88" Text="{Binding CmpPingDeltaText}" Foreground="{Binding CmpPingDeltaBrush}" FontSize="20" FontWeight="SemiBold" TextAlignment="Left"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Width="88" Text="лидер" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Right"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Width="14" Text="|" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Width="88" Text="выбранный" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Left"/>
                                    </Grid>
                                </GroupBox>
                            </UniformGrid>
                            <UniformGrid Rows="1" Columns="4" Grid.Row="1" Margin="-4,16,-4,0">
                                <GroupBox Header="Ср. джиттер, мс" Margin="4,0,4,0"
                                          ToolTip="Джиттер — колебание задержки (стабильность канала). Чем меньше, тем лучше: «+Δ» хуже, «−Δ» лучше.">
                                    <Grid HorizontalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Width="88" Text="{Binding CmpJitterLeaderText}" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold" TextAlignment="Right"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Width="14" Text="{Binding CmpJitterSeparatorText}" Foreground="{StaticResource MutedTextBrush}" FontSize="16" FontWeight="Normal" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Width="88" Text="{Binding CmpJitterDeltaText}" Foreground="{Binding CmpJitterDeltaBrush}" FontSize="20" FontWeight="SemiBold" TextAlignment="Left"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Width="88" Text="лидер" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Right"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Width="14" Text="|" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Width="88" Text="выбранный" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Left"/>
                                    </Grid>
                                </GroupBox>
                                <GroupBox Header="Ср. потери %" Margin="4,0,4,0"
                                          ToolTip="Потери — доля потерянных пакетов в %. Чем меньше, тем лучше: «+Δ» хуже, «−Δ» лучше.">
                                    <Grid HorizontalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Width="88" Text="{Binding CmpLossLeaderText}" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold" TextAlignment="Right"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Width="14" Text="{Binding CmpLossSeparatorText}" Foreground="{StaticResource MutedTextBrush}" FontSize="16" FontWeight="Normal" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Width="88" Text="{Binding CmpLossDeltaText}" Foreground="{Binding CmpLossDeltaBrush}" FontSize="20" FontWeight="SemiBold" TextAlignment="Left"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Width="88" Text="лидер" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Right"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Width="14" Text="|" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Width="88" Text="выбранный" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Left"/>
                                    </Grid>
                                </GroupBox>
                                <GroupBox Header="Ср. загрузка, Мбит/с" Margin="4,0,4,0"
                                          ToolTip="Загрузка — скорость получения данных (download). Чем больше, тем лучше: «+Δ» лучше, «−Δ» хуже.">
                                    <Grid HorizontalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Width="88" Text="{Binding CmpDownLeaderText}" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold" TextAlignment="Right"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Width="14" Text="{Binding CmpDownSeparatorText}" Foreground="{StaticResource MutedTextBrush}" FontSize="16" FontWeight="Normal" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Width="88" Text="{Binding CmpDownDeltaText}" Foreground="{Binding CmpDownDeltaBrush}" FontSize="20" FontWeight="SemiBold" TextAlignment="Left"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Width="88" Text="лидер" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Right"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Width="14" Text="|" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Width="88" Text="выбранный" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Left"/>
                                    </Grid>
                                </GroupBox>
                                <GroupBox Header="Ср. отдача, Мбит/с" Margin="4,0,4,0"
                                          ToolTip="Отдача — скорость отправки данных (upload). Чем больше, тем лучше: «+Δ» лучше, «−Δ» хуже.">
                                    <Grid HorizontalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Width="88" Text="{Binding CmpUpLeaderText}" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold" TextAlignment="Right"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Width="14" Text="{Binding CmpUpSeparatorText}" Foreground="{StaticResource MutedTextBrush}" FontSize="16" FontWeight="Normal" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Width="88" Text="{Binding CmpUpDeltaText}" Foreground="{Binding CmpUpDeltaBrush}" FontSize="20" FontWeight="SemiBold" TextAlignment="Left"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Width="88" Text="лидер" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Right"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Width="14" Text="|" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Width="88" Text="выбранный" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextAlignment="Left"/>
                                    </Grid>
                                </GroupBox>
                            </UniformGrid>
                        </Grid>

                        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border CornerRadius="8" BorderBrush="{StaticResource PanelSecondaryBrush}" BorderThickness="1" ClipToBounds="True">
                                    <DataGrid ItemsSource="{Binding HostRatings}"
                                              SelectedItem="{Binding SelectedHostRatingRow, Mode=TwoWay}"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              IsSynchronizedWithCurrentItem="False"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Rank}" Value="1"/>
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="#3B2F10"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Rank}" Value="2"/>
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="#2D3440"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Rank}" Value="3"/>
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="#3A2A24"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="" Width="0.55*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding RankMarker}"
                                                                   Foreground="{Binding RankMarkerColor}"
                                                                   ToolTip="{Binding RankMarkerToolTip}"
                                                                   FontSize="14"
                                                                   TextAlignment="Center"
                                                                   Margin="0,-1,0,0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Место" Binding="{Binding Rank}" Width="0.6*" SortMemberPath="Rank"/>
                                            <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="1.2*"/>
                                            <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="1*"/>
                                            <DataGridTextColumn Header="Замеры" Binding="{Binding Samples}" Width="0.7*"/>
                                            <DataGridTextColumn Header="Ср. D.Q.S" Binding="{Binding AverageScore, StringFormat=F2}" Width="0.9*"/>
                                            <DataGridTextColumn Header="Лучший D.Q.S" Binding="{Binding BestScore, StringFormat=F2}" Width="0.9*"/>
                                            <DataGridTextColumn Header="Ср. пинг" Binding="{Binding AveragePing, StringFormat=F2}" Width="0.9*"/>
                                            <DataGridTextColumn Header="Ср. джиттер" Binding="{Binding AverageJitter, StringFormat=F2}" Width="1*"/>
                                            <DataGridTextColumn Header="Ср. потери" Binding="{Binding AverageLoss, StringFormat=F2}" Width="0.9*"/>
                                            <DataGridTextColumn Header="Ср. загрузка" Binding="{Binding AverageDownloadMbps, StringFormat=F2}" Width="1*"/>
                                            <DataGridTextColumn Header="Ср. отдача" Binding="{Binding AverageUploadMbps, StringFormat=F2}" Width="1*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding BestHostSummaryText}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding RatingSummaryText}" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding StabilitySummaryText}" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="8,8,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="{Binding ToggleMonitoringButtonText}" Width="130" Margin="0,0,8,0" Command="{Binding ToggleMonitoringCommand}"/>
                <Button Content="Замер сейчас" Width="140" Margin="0,0,8,0" Command="{Binding RunNowCommand}"/>
                <Button Content="{Binding ActiveExportButtonText}" Width="150" Margin="0" Command="{Binding ActiveExportCommand}"/>
            </StackPanel>

            <TextBlock Grid.Column="2"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedTextBrush}"
                       Opacity="0.85"
                       FontSize="11">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Padding="6,3"
                            Margin="0,0,10,0"
                            ToolTip="Открыть папку логов"
                            Click="OpenLogs_Click">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="14"/>
                    </Button>
                    <Button Padding="6,3"
                            Margin="0,0,10,0"
                            ToolTip="О приложении"
                            Click="About_Click">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="14"/>
                    </Button>
                </StackPanel>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
