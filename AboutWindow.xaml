<Window x:Class="VpnSpeedAnalyzer.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О приложении"
        Width="560"
        Height="420"
        MinWidth="520"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="10"
                MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="VPN Speed Analyzer"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center">
                <Run Text="Версия: " Foreground="{StaticResource MutedTextBrush}"/>
                <Hyperlink Foreground="{StaticResource OkBrush}"
                           TextDecorations="{x:Null}"
                           Cursor="Hand"
                           Click="OpenRelease_Click">
                    <Run Text="{Binding AppVersion}"/>
                </Hyperlink>
            </TextBlock>
        </Grid>

        <Border Grid.Row="1"
                Background="#171A2C"
                BorderBrush="{StaticResource PanelSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10"
                Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Что нового"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontWeight="SemiBold"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,8,0,0">
                    <TextBlock Text="{Binding ReleaseNotes}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextBrush}"/>
                </ScrollViewer>
            </Grid>
        </Border>

        </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button Content="Закрыть"
                        Width="100"
                        Click="Close_Click"/>
            </StackPanel>

            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right">
                <Hyperlink Foreground="{StaticResource OkBrush}"
                           TextDecorations="{x:Null}"
                           Cursor="Hand"
                           Click="OpenProject_Click">
                    created by daver
                </Hyperlink>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
