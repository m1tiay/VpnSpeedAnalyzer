<Window x:Class="VpnSpeedAnalyzer.AboutWindow"
        x:Name="AboutRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О приложении"
        Width="560"
        Height="420"
        MinWidth="520"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">
    <Grid Margin="24,12,24,12">
        <Border Background="{StaticResource BgBrush}"
                BorderBrush="{StaticResource PanelSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="VPN Speed Analyzer"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"/>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="Версия: "
                           Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock Text="{Binding AppVersion}"
                           Foreground="{StaticResource OkBrush}"
                           Cursor="Hand"
                           MouseLeftButtonDown="OpenReleaseText_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10"
                Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Что нового"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontWeight="SemiBold"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,8,0,0">
                    <TextBlock Text="{Binding ReleaseNotes}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextBrush}"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left">
                <Hyperlink Foreground="{StaticResource OkBrush}"
                           TextDecorations="{x:Null}"
                           Cursor="Hand"
                           Click="OpenProject_Click">
                    created by daver
                </Hyperlink>
            </TextBlock>

            <Button Grid.Column="1"
                    Content="Закрыть"
                    Width="100"
                    Margin="0"
                    HorizontalAlignment="Right"
                    Click="Close_Click"/>
        </Grid>
        </Grid>
        </Border>
    </Grid>
</Window>
